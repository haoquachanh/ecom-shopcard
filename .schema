-- ======================================================
-- ECOM SHOPCARD DATABASE SCHEMA (POSTGRESQL / SUPABASE)
-- Frontend public reads use anon SELECT policies.
-- Admin/backend writes should go through the backend, not the frontend.
-- ======================================================

-- ---------- Types ----------
DO $$
BEGIN
  IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = 'user_role') THEN
    CREATE TYPE user_role AS ENUM ('user', 'admin');
  END IF;

  IF NOT EXISTS (SELECT 1 FROM pg_type WHERE typname = 'order_status') THEN
    CREATE TYPE order_status AS ENUM ('pending', 'confirmed', 'printing', 'shipped', 'cancelled');
  END IF;
END;
$$;

-- ---------- Core auth/users ----------
CREATE TABLE IF NOT EXISTS users (
  id SERIAL PRIMARY KEY,
  email VARCHAR(255) NOT NULL UNIQUE,
  password VARCHAR(255) NOT NULL,
  name VARCHAR(120),
  phone VARCHAR(30),
  address TEXT,
  role user_role NOT NULL DEFAULT 'user',
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_users_role ON users(role);
CREATE INDEX IF NOT EXISTS idx_users_is_active ON users(is_active);

-- ---------- Catalog ----------
CREATE TABLE IF NOT EXISTS product_types (
  id SERIAL PRIMARY KEY,
  name VARCHAR(100) NOT NULL UNIQUE,
  slug VARCHAR(140) UNIQUE,
  description TEXT,
  image_url VARCHAR(500),
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  sort_order INT NOT NULL DEFAULT 0,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE product_types ADD COLUMN IF NOT EXISTS slug VARCHAR(140);
CREATE UNIQUE INDEX IF NOT EXISTS uq_product_types_slug ON product_types(slug) WHERE slug IS NOT NULL;
CREATE INDEX IF NOT EXISTS idx_product_types_public_sort ON product_types(is_active, sort_order, id);

CREATE TABLE IF NOT EXISTS samples (
  id SERIAL PRIMARY KEY,
  product_type_id INT NOT NULL REFERENCES product_types(id) ON DELETE CASCADE,
  name VARCHAR(200) NOT NULL,
  slug VARCHAR(240) UNIQUE,
  description TEXT,
  image_url VARCHAR(500),
  thumbnail_url VARCHAR(500),
  tags TEXT[] NOT NULL DEFAULT '{}',
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  sort_order INT NOT NULL DEFAULT 0,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE samples ADD COLUMN IF NOT EXISTS slug VARCHAR(240);
ALTER TABLE samples ADD COLUMN IF NOT EXISTS thumbnail_url VARCHAR(500);
ALTER TABLE samples ADD COLUMN IF NOT EXISTS tags TEXT[] NOT NULL DEFAULT '{}';
ALTER TABLE samples ADD COLUMN IF NOT EXISTS sort_order INT NOT NULL DEFAULT 0;
CREATE UNIQUE INDEX IF NOT EXISTS uq_samples_slug ON samples(slug) WHERE slug IS NOT NULL;
CREATE INDEX IF NOT EXISTS idx_samples_product_type ON samples(product_type_id);
CREATE INDEX IF NOT EXISTS idx_samples_public_sort ON samples(is_active, product_type_id, sort_order, id);

CREATE TABLE IF NOT EXISTS sample_images (
  id SERIAL PRIMARY KEY,
  sample_id INT NOT NULL REFERENCES samples(id) ON DELETE CASCADE,
  image_url VARCHAR(500) NOT NULL,
  alt_text VARCHAR(200),
  sort_order INT NOT NULL DEFAULT 0,
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_sample_images_sample_sort ON sample_images(sample_id, is_active, sort_order, id);

-- Optional home/banner content for public frontend.
CREATE TABLE IF NOT EXISTS banners (
  id SERIAL PRIMARY KEY,
  title VARCHAR(200) NOT NULL,
  subtitle TEXT,
  image_url VARCHAR(500),
  link_url VARCHAR(500),
  placement VARCHAR(80) NOT NULL DEFAULT 'home',
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  sort_order INT NOT NULL DEFAULT 0,
  starts_at TIMESTAMPTZ,
  ends_at TIMESTAMPTZ,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_banners_public ON banners(placement, is_active, sort_order, id);

-- ---------- Pricing dimensions ----------
CREATE TABLE IF NOT EXISTS materials (
  id SERIAL PRIMARY KEY,
  name VARCHAR(100) NOT NULL UNIQUE,
  display_order INT NOT NULL DEFAULT 0,
  is_active BOOLEAN NOT NULL DEFAULT TRUE
);

CREATE INDEX IF NOT EXISTS idx_materials_public_sort ON materials(is_active, display_order, id);

CREATE TABLE IF NOT EXISTS sizes (
  id SERIAL PRIMARY KEY,
  name VARCHAR(100) NOT NULL UNIQUE,
  sort_order INT NOT NULL DEFAULT 0,
  is_active BOOLEAN NOT NULL DEFAULT TRUE
);

CREATE INDEX IF NOT EXISTS idx_sizes_public_sort ON sizes(is_active, sort_order, id);

CREATE TABLE IF NOT EXISTS effects (
  id SERIAL PRIMARY KEY,
  name VARCHAR(100) NOT NULL UNIQUE,
  is_active BOOLEAN NOT NULL DEFAULT TRUE
);

CREATE INDEX IF NOT EXISTS idx_effects_public_sort ON effects(is_active, id);

CREATE TABLE IF NOT EXISTS sides (
  id SERIAL PRIMARY KEY,
  name VARCHAR(50) NOT NULL UNIQUE,
  sort_order INT NOT NULL DEFAULT 0,
  is_active BOOLEAN NOT NULL DEFAULT TRUE
);

ALTER TABLE sides ADD COLUMN IF NOT EXISTS sort_order INT NOT NULL DEFAULT 0;
ALTER TABLE sides ADD COLUMN IF NOT EXISTS is_active BOOLEAN NOT NULL DEFAULT TRUE;
CREATE INDEX IF NOT EXISTS idx_sides_public_sort ON sides(is_active, sort_order, id);

CREATE TABLE IF NOT EXISTS base_prices (
  id SERIAL PRIMARY KEY,
  product_type_id INT REFERENCES product_types(id) ON DELETE SET NULL,
  material_id INT NOT NULL REFERENCES materials(id) ON DELETE RESTRICT,
  size_id INT NOT NULL REFERENCES sizes(id) ON DELETE RESTRICT,
  side_id INT NOT NULL REFERENCES sides(id) ON DELETE RESTRICT,
  effect_id INT REFERENCES effects(id) ON DELETE SET NULL,
  unit_price NUMERIC(12,2) NOT NULL CHECK (unit_price >= 0),
  is_active BOOLEAN NOT NULL DEFAULT TRUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

ALTER TABLE base_prices ADD COLUMN IF NOT EXISTS is_active BOOLEAN NOT NULL DEFAULT TRUE;
CREATE INDEX IF NOT EXISTS idx_base_prices_lookup ON base_prices(product_type_id, material_id, size_id, side_id, effect_id);
CREATE INDEX IF NOT EXISTS idx_base_prices_public ON base_prices(is_active, product_type_id);
CREATE UNIQUE INDEX IF NOT EXISTS uq_base_prices_combo_normalized
  ON base_prices (
    COALESCE(product_type_id, 0),
    material_id,
    size_id,
    side_id,
    COALESCE(effect_id, 0)
  );

CREATE TABLE IF NOT EXISTS quantity_tiers (
  id SERIAL PRIMARY KEY,
  base_price_id INT NOT NULL REFERENCES base_prices(id) ON DELETE CASCADE,
  min_quantity INT NOT NULL CHECK (min_quantity >= 1),
  max_quantity INT CHECK (max_quantity IS NULL OR max_quantity >= min_quantity),
  price_per_unit NUMERIC(12,2) NOT NULL CHECK (price_per_unit >= 0),
  is_active BOOLEAN NOT NULL DEFAULT TRUE
);

ALTER TABLE quantity_tiers ADD COLUMN IF NOT EXISTS is_active BOOLEAN NOT NULL DEFAULT TRUE;
CREATE INDEX IF NOT EXISTS idx_quantity_tiers_base_price ON quantity_tiers(base_price_id);
CREATE INDEX IF NOT EXISTS idx_quantity_tiers_lookup ON quantity_tiers(base_price_id, is_active, min_quantity, max_quantity);

-- ---------- Wishlist ----------
CREATE TABLE IF NOT EXISTS wishlist (
  id SERIAL PRIMARY KEY,
  user_id INT NOT NULL REFERENCES users(id) ON DELETE CASCADE,
  product_type_id INT NOT NULL REFERENCES product_types(id) ON DELETE CASCADE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  CONSTRAINT uq_wishlist_user_product_type UNIQUE (user_id, product_type_id)
);

CREATE INDEX IF NOT EXISTS idx_wishlist_user ON wishlist(user_id);

-- ---------- Cart/order tables, reserved for backend workflows ----------
CREATE TABLE IF NOT EXISTS carts (
  id SERIAL PRIMARY KEY,
  user_id INT REFERENCES users(id) ON DELETE SET NULL,
  session_id VARCHAR(255),
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_carts_user ON carts(user_id);
CREATE INDEX IF NOT EXISTS idx_carts_session ON carts(session_id);

CREATE TABLE IF NOT EXISTS cart_items (
  id SERIAL PRIMARY KEY,
  cart_id INT NOT NULL REFERENCES carts(id) ON DELETE CASCADE,
  sample_id INT NOT NULL REFERENCES samples(id) ON DELETE RESTRICT,
  material_id INT NOT NULL REFERENCES materials(id) ON DELETE RESTRICT,
  size_id INT NOT NULL REFERENCES sizes(id) ON DELETE RESTRICT,
  side_id INT NOT NULL REFERENCES sides(id) ON DELETE RESTRICT,
  effect_id INT REFERENCES effects(id) ON DELETE SET NULL,
  quantity INT NOT NULL CHECK (quantity > 0),
  unit_price NUMERIC(12,2) NOT NULL CHECK (unit_price >= 0),
  total_price NUMERIC(12,2) NOT NULL CHECK (total_price >= 0)
);

CREATE INDEX IF NOT EXISTS idx_cart_items_cart ON cart_items(cart_id);

CREATE TABLE IF NOT EXISTS orders (
  id SERIAL PRIMARY KEY,
  user_id INT REFERENCES users(id) ON DELETE SET NULL,
  order_number VARCHAR(50) NOT NULL UNIQUE,
  status order_status NOT NULL DEFAULT 'pending',
  customer_name VARCHAR(120) NOT NULL,
  customer_email VARCHAR(255) NOT NULL,
  customer_phone VARCHAR(30) NOT NULL,
  customer_address TEXT NOT NULL,
  shipping_fee NUMERIC(12,2) NOT NULL DEFAULT 0 CHECK (shipping_fee >= 0),
  discount_total NUMERIC(12,2) NOT NULL DEFAULT 0 CHECK (discount_total >= 0),
  grand_total NUMERIC(12,2) NOT NULL CHECK (grand_total >= 0),
  payment_method VARCHAR(50),
  payment_status VARCHAR(50) NOT NULL DEFAULT 'pending',
  notes TEXT,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS idx_orders_user ON orders(user_id);
CREATE INDEX IF NOT EXISTS idx_orders_status ON orders(status);

CREATE TABLE IF NOT EXISTS order_items (
  id SERIAL PRIMARY KEY,
  order_id INT NOT NULL REFERENCES orders(id) ON DELETE CASCADE,
  product_type_id INT NOT NULL REFERENCES product_types(id) ON DELETE RESTRICT,
  sample_id INT NOT NULL REFERENCES samples(id) ON DELETE RESTRICT,
  material_name VARCHAR(100) NOT NULL,
  size_name VARCHAR(100) NOT NULL,
  side_name VARCHAR(100) NOT NULL,
  effect_name VARCHAR(100),
  quantity INT NOT NULL CHECK (quantity > 0),
  unit_price NUMERIC(12,2) NOT NULL CHECK (unit_price >= 0),
  total_price NUMERIC(12,2) NOT NULL CHECK (total_price >= 0)
);

CREATE INDEX IF NOT EXISTS idx_order_items_order ON order_items(order_id);

-- ---------- updated_at trigger helper ----------
CREATE OR REPLACE FUNCTION update_updated_at_column()
RETURNS TRIGGER AS $$
BEGIN
  NEW.updated_at = NOW();
  RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS trg_users_updated_at ON users;
CREATE TRIGGER trg_users_updated_at BEFORE UPDATE ON users
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_product_types_updated_at ON product_types;
CREATE TRIGGER trg_product_types_updated_at BEFORE UPDATE ON product_types
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_samples_updated_at ON samples;
CREATE TRIGGER trg_samples_updated_at BEFORE UPDATE ON samples
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_banners_updated_at ON banners;
CREATE TRIGGER trg_banners_updated_at BEFORE UPDATE ON banners
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_base_prices_updated_at ON base_prices;
CREATE TRIGGER trg_base_prices_updated_at BEFORE UPDATE ON base_prices
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_carts_updated_at ON carts;
CREATE TRIGGER trg_carts_updated_at BEFORE UPDATE ON carts
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

DROP TRIGGER IF EXISTS trg_orders_updated_at ON orders;
CREATE TRIGGER trg_orders_updated_at BEFORE UPDATE ON orders
FOR EACH ROW EXECUTE FUNCTION update_updated_at_column();

-- ---------- Row Level Security ----------
ALTER TABLE users ENABLE ROW LEVEL SECURITY;
ALTER TABLE product_types ENABLE ROW LEVEL SECURITY;
ALTER TABLE samples ENABLE ROW LEVEL SECURITY;
ALTER TABLE sample_images ENABLE ROW LEVEL SECURITY;
ALTER TABLE banners ENABLE ROW LEVEL SECURITY;
ALTER TABLE materials ENABLE ROW LEVEL SECURITY;
ALTER TABLE sizes ENABLE ROW LEVEL SECURITY;
ALTER TABLE effects ENABLE ROW LEVEL SECURITY;
ALTER TABLE sides ENABLE ROW LEVEL SECURITY;
ALTER TABLE base_prices ENABLE ROW LEVEL SECURITY;
ALTER TABLE quantity_tiers ENABLE ROW LEVEL SECURITY;
ALTER TABLE wishlist ENABLE ROW LEVEL SECURITY;
ALTER TABLE carts ENABLE ROW LEVEL SECURITY;
ALTER TABLE cart_items ENABLE ROW LEVEL SECURITY;
ALTER TABLE orders ENABLE ROW LEVEL SECURITY;
ALTER TABLE order_items ENABLE ROW LEVEL SECURITY;

-- Supabase REST/PostgREST also requires table privileges in addition to RLS policies.
GRANT USAGE ON SCHEMA public TO anon;
GRANT SELECT ON TABLE
  product_types,
  samples,
  sample_images,
  banners,
  materials,
  sizes,
  effects,
  sides,
  base_prices,
  quantity_tiers
TO anon;

-- Public frontend: SELECT only active public catalog/pricing/content.
DROP POLICY IF EXISTS "Public active product types" ON product_types;
CREATE POLICY "Public active product types"
ON product_types FOR SELECT
TO anon
USING (is_active = true);

DROP POLICY IF EXISTS "Public active samples" ON samples;
CREATE POLICY "Public active samples"
ON samples FOR SELECT
TO anon
USING (
  is_active = true
  AND EXISTS (
    SELECT 1
    FROM product_types
    WHERE product_types.id = samples.product_type_id
      AND product_types.is_active = true
  )
);

DROP POLICY IF EXISTS "Public active sample images" ON sample_images;
CREATE POLICY "Public active sample images"
ON sample_images FOR SELECT
TO anon
USING (
  is_active = true
  AND EXISTS (
    SELECT 1
    FROM samples
    JOIN product_types ON product_types.id = samples.product_type_id
    WHERE samples.id = sample_images.sample_id
      AND samples.is_active = true
      AND product_types.is_active = true
  )
);

DROP POLICY IF EXISTS "Public active banners" ON banners;
CREATE POLICY "Public active banners"
ON banners FOR SELECT
TO anon
USING (
  is_active = true
  AND (starts_at IS NULL OR starts_at <= NOW())
  AND (ends_at IS NULL OR ends_at >= NOW())
);

DROP POLICY IF EXISTS "Public active materials" ON materials;
CREATE POLICY "Public active materials"
ON materials FOR SELECT
TO anon
USING (is_active = true);

DROP POLICY IF EXISTS "Public active sizes" ON sizes;
CREATE POLICY "Public active sizes"
ON sizes FOR SELECT
TO anon
USING (is_active = true);

DROP POLICY IF EXISTS "Public active effects" ON effects;
CREATE POLICY "Public active effects"
ON effects FOR SELECT
TO anon
USING (is_active = true);

DROP POLICY IF EXISTS "Public active sides" ON sides;
CREATE POLICY "Public active sides"
ON sides FOR SELECT
TO anon
USING (is_active = true);

DROP POLICY IF EXISTS "Public active base prices" ON base_prices;
CREATE POLICY "Public active base prices"
ON base_prices FOR SELECT
TO anon
USING (
  is_active = true
  AND EXISTS (SELECT 1 FROM materials WHERE materials.id = base_prices.material_id AND materials.is_active = true)
  AND EXISTS (SELECT 1 FROM sizes WHERE sizes.id = base_prices.size_id AND sizes.is_active = true)
  AND EXISTS (SELECT 1 FROM sides WHERE sides.id = base_prices.side_id AND sides.is_active = true)
  AND (
    effect_id IS NULL
    OR EXISTS (SELECT 1 FROM effects WHERE effects.id = base_prices.effect_id AND effects.is_active = true)
  )
  AND (
    product_type_id IS NULL
    OR EXISTS (
      SELECT 1
      FROM product_types
      WHERE product_types.id = base_prices.product_type_id
        AND product_types.is_active = true
    )
  )
);

DROP POLICY IF EXISTS "Public active quantity tiers" ON quantity_tiers;
CREATE POLICY "Public active quantity tiers"
ON quantity_tiers FOR SELECT
TO anon
USING (
  is_active = true
  AND EXISTS (
    SELECT 1
    FROM base_prices
    LEFT JOIN product_types ON product_types.id = base_prices.product_type_id
    WHERE base_prices.id = quantity_tiers.base_price_id
      AND base_prices.is_active = true
      AND (base_prices.product_type_id IS NULL OR product_types.is_active = true)
  )
);

-- No anon/authenticated INSERT/UPDATE/DELETE policies are created here.
-- Mutations for users, wishlist, cart, orders, admin catalog, and pricing
-- should go through the backend.
